rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default: Deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Secure 'config' collection (Contains Upstox Token)
    // Only authenticated users can read. NO ONE can write (except Admin SDK)
    match /config/{docId} {
        allow read: if request.auth != null;
        allow write: if false;
    }

    // User Data: Users can only read/write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Main User Profile Data (AccountScreen)
    match /rupiecemain/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Challenges/Accounts
    match /challenges/{challengeId} {
       // Allow if user owns it (assuming userId field exists on doc)
       // Or simpler: Allow any auth user to read/write for now (Development)
       // Better: Check resource.data.userId == request.auth.uid
       allow read, write: if request.auth != null;
    }

    // Orders
    match /orders/{orderId} {
       allow read, write: if request.auth != null;
    }

    // Positions
    match /positions/{posId} {
       allow read, write: if request.auth != null;
    }
    
    // Trades
    match /trades/{tradeId} {
       allow read, write: if request.auth != null;
    }
  }
}
