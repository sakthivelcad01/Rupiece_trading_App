rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // Core user data
    // ------------------------------------------------------------
    match /rupiecemain/{userId} {
      // Allow read to authenticated users for leaderboard display (name etc.)
      // Sensitive data should be protected by field-level rules or separate collection if needed in future
      allow read: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // ------------------------------------------------------------
    // Config (Upstox token) – public read for server unblocking (trusted dev environment)
    // ------------------------------------------------------------
    match /config/upstox {
      allow read: if true;
      allow write: if false;
    }
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ------------------------------------------------------------
    // Challenges (accounts)
    // ------------------------------------------------------------
    // ------------------------------------------------------------
    // Challenges (accounts)
    // ------------------------------------------------------------
    match /challenges/{challengeId} {
      // Creation – only the owner can create a competition challenge
      allow create: if request.resource.data.isCompetition == true && request.auth != null && request.resource.data.userId == request.auth.uid;

      // Read – owner, linked email, passed leaderboard, or competition challenge
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.email == request.auth.token.email ||
        resource.data.accountStatus == 'passed' ||
        resource.data.isCompetition == true
      );

      // Update – BLOCKED (Server Only)
      allow update: if false;
    }

    // ------------------------------------------------------------
    // Miscellaneous collections (unchanged)
    // ------------------------------------------------------------
    match /commissions/{commissionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.referrerId;
      allow create: if false; // Only Server can create commissions
    }

    match /withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /affiliate_withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /offer/{offerId} {
      allow read: if true;
    }

    match /messages/{messageId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /reward_submissions/{submissionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId);
    }

    match /news/{newsId} {
      allow read: if true;
    }

    match /certificates/{certificateId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if false; // Only server (admin SDK) creates certificates
    }

    match /competition_registrations/{registrationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /reward_redemptions/{reductionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ------------------------------------------------------------
    // Trading data collections – ownership via `accountId` (challenge) or fallback `userId`
    // ------------------------------------------------------------
    // Orders
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        (resource == null) || // Allow reading non-existent? (For queries usually not needed)
        (resource.data.accountId != null && get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
      allow write: if false;
    }

    // Positions
    match /positions/{positionId} {
      allow read: if request.auth != null && (
        (resource.data.accountId != null && get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
      allow write: if false;
    }

    // Trades
    match /trades/{tradeId} {
      allow read: if request.auth != null && (
        (resource.data.accountId != null && get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
        (resource.data.userId != null && resource.data.userId == request.auth.uid)
      );
      allow write: if false;
    }

    // ------------------------------------------------------------
    // Miscellaneous collections (unchanged)
    // ------------------------------------------------------------
    match /commissions/{commissionId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.referrerId;
      allow create: if false; // Only Server can create commissions
    }

    match /withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /affiliate_withdrawals/{withdrawalId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /offer/{offerId} {
      allow read: if true;
    }

    match /messages/{messageId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }

    match /reward_submissions/{submissionId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId);
    }

    match /news/{newsId} {
      allow read: if true;
    }

    match /certificates/{certificateId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if false; // Only server (admin SDK) creates certificates
    }

    match /competition_registrations/{registrationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /reward_redemptions/{reductionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ------------------------------------------------------------
    // Trading data collections – ownership via `accountId` (challenge) or fallback `userId`
    // ------------------------------------------------------------
    // Orders
    match /orders/{orderId} {
      allow read, write: if request.auth != null && (
        // Allow reading non-existent docs (vital for transaction checks)
        (resource == null && request.resource == null) ||

        // Write (Create/Update): check NEW data
        (request.resource != null && (
          (request.resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(request.resource.data.accountId)).data.userId == request.auth.uid) ||
          (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
        )) ||

        // Read (Existing) or Write (Delete): check EXISTING data
        (resource != null && (
          (resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
          (resource.data.userId != null && resource.data.userId == request.auth.uid)
        ))
      );
    }

    // Positions
    match /positions/{positionId} {
      allow read, write: if request.auth != null && (
        // Allow reading non-existent docs
        (resource == null && request.resource == null) ||

        // Write (Create/Update): check NEW data
        (request.resource != null && (
          (request.resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(request.resource.data.accountId)).data.userId == request.auth.uid) ||
          (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
        )) ||

        // Read (Existing) or Write (Delete): check EXISTING data
        (resource != null && (
          (resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
          (resource.data.userId != null && resource.data.userId == request.auth.uid)
        ))
      );
    }

    // Trades
    match /trades/{tradeId} {
      allow read, write: if request.auth != null && (
        // Allow reading non-existent docs
        (resource == null && request.resource == null) ||

        // Write (Create/Update): check NEW data
        (request.resource != null && (
          (request.resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(request.resource.data.accountId)).data.userId == request.auth.uid) ||
          (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid)
        )) ||

        // Read (Existing) or Write (Delete): check EXISTING data
        (resource != null && (
          (resource.data.accountId != null &&
            get(/databases/$(database)/documents/challenges/$(resource.data.accountId)).data.userId == request.auth.uid) ||
          (resource.data.userId != null && resource.data.userId == request.auth.uid)
        ))
      );
    }

    // ------------------------------------------------------------
    // Pre‑registration (unchanged)
    // ------------------------------------------------------------
    match /preregisteruser/{userId} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
    }
  }
}
